# ===========================================
#  Becxus Exchange - Environment Variables
#  Copy this file to .env and fill in values
#  cp .env.example .env  (Linux/Mac)
#  copy .env.example .env  (Windows)
# ===========================================

# Supabase Configuration (server-side)
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Supabase Configuration (client-side — VITE_ prefix required by Vite)
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Database (Supabase PostgreSQL connection string)
DATABASE_URL=postgresql://postgres:your-password@db.your-project-id.supabase.co:5432/postgres

# Server
PORT=5050

# Redis (optional - app works without it, but caching improves performance)
REDIS_URL=redis://localhost:6379

# Application metadata
APP_NAME=Becxus Exchange
PUBLIC_URL=http://localhost:5050
ALLOWED_ORIGINS=http://localhost:5050

# Client (Vite) application metadata and URLs
VITE_APP_NAME=Becxus Exchange
VITE_PUBLIC_URL=http://localhost:5050
VITE_API_BASE_URL=http://localhost:5050
VITE_WS_BASE_URL=ws://localhost:5050
VITE_FORCE_HTTPS=false

# Notes:
# - For production/staging, set PUBLIC_URL to your HTTPS domain (e.g., https://app.becxus.com)
# - ALLOWED_ORIGINS should be a comma-separated list of origins allowed by CORS
# - VITE_* variables are exposed to the frontend via import.meta.env
# - Push notifications require VAPID keys (generate with web-push)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@example.com
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
